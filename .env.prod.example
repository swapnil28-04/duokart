# ── Copy this file to .env.prod and fill in your values ──────────
# This file is loaded by docker-compose.prod.yml on the EC2 instance.
# NEVER commit .env.prod to git.

# AWS ECR config (used by deploy.sh and docker-compose.prod.yml)
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# MongoDB credentials (used inside the Docker network)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_use_a_strong_password

# JWT secret — generate one with: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret
