# ── Server ──────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── MongoDB ─────────────────────────────────────────────
# For EC2 / Docker Compose (MongoDB running in container):
MONGO_URI=mongodb://admin:changeme@mongodb:27017/duokart?authSource=admin

# For MongoDB Atlas (replace with your Atlas connection string):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/duokart?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace_this_with_a_strong_random_secret
